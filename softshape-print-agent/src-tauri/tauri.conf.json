{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "SoftShape Print Agent",
    "version": "0.1.0"
  },
  "tauri": {
    "windows": [
      {
        "title": "SoftShape Print Agent",
        "url": "https://www.softshape.in/print-agent",
        "width": 560,
        "height": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "allowlist": {
      "all": false,
      "http": {
        "all": false,
        "request": true,
        "scope": [
          "http://localhost:3000",
          "https://softshape-backend.onrender.com"
        ]
      }
    },
    "security": {
      "csp": null
    },
    "bundle": {
      "identifier": "ai.softshape.print-agent",
      "active": true,
      "targets": ["nsis", "msi"],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.ico"
      ],
      "windows": {
        "webviewInstallMode": {
          "type": "embedBootstrapper"
        }
      }
    }
  }
}
