{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "SoftShape Print Agent",
    "version": "4.0.0"
  },
  "tauri": {
    "windows": [
      {
        "title": "SoftShape Print Agent",
        "width": 560,
        "height": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "allowlist": {
      "all": false,
      "http": {
        "all": false,
        "request": true,
        "scope": [
          "http://localhost:3000",
          "https://softshape-backend.onrender.com"
        ]
      }
    },
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http: https: ws: wss:; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:;"
    },
    "bundle": {
      "identifier": "ai.softshape.print-agent",
      "active": true,
      "targets": ["nsis", "msi"],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.ico"
      ],
      "windows": {
        "webviewInstallMode": {
          "type": "embedBootstrapper"
        }
      }
    }
  }
}
