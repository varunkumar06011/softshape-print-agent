# Softshape Windows Print Agent — Environment Variables

# Backend API URL that the agent connects to for print jobs.
# REQUIRED at build time — the agent bakes this URL into the bundle.
# For local development:
VITE_BACKEND_URL=http://localhost:3000

# For production, set this to the deployed Print Agent backend.
# NOTE: The print agent is a standalone app — it connects to its own backend,
# not softshape.in. CI bakes this value in via .github/workflows/build-print-agent.yml.
# VITE_BACKEND_URL=https://softshape-backend-production.up.railway.app
